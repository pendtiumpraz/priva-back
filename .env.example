APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ═════════════════════════════════════════════════════════════════════
# Frontend OTA updates (/system-update "Update Frontend" button)
# ═════════════════════════════════════════════════════════════════════
# Mode: "shell" (same-server git pull + npm build + reload) or "webhook"
# (POST a deploy hook URL — e.g. Vercel, Netlify, GitHub dispatch).
FRONTEND_DEPLOY_MODE=shell

# --- Shell mode only ---
# Absolute path to the frontend git checkout
FRONTEND_PATH=/var/www/nexus-frontend
# Absolute path to npm/node binaries. Leave empty if already in the
# PHP-FPM user's PATH. Set when using nvm or a non-system Node install.
NPM_BIN=
NODE_BIN=
# Command the PHP-FPM user can run to reload the Next.js process
# after build. Examples:
#   pm2 reload nexus-frontend
#   systemctl --user restart nexus-frontend
#   docker compose restart frontend
FRONTEND_RELOAD_CMD=

# --- Webhook mode only ---
# Vercel Deploy Hook URL, Netlify build hook, GitHub workflow_dispatch,
# or a self-hosted webhook endpoint (e.g., adnanh/webhook) on the
# frontend server.
FRONTEND_DEPLOY_HOOK_URL=
# Optional HTTP verb (POST default) — some webhooks only accept GET.
FRONTEND_DEPLOY_HOOK_METHOD=POST
# Optional auth header. Leave empty to skip auth.
FRONTEND_DEPLOY_HOOK_HEADER=X-Deploy-Secret
FRONTEND_DEPLOY_HOOK_SECRET=

# ===================================
# CORS allowlist (security)
# ===================================
# Comma-separated list of frontend origins yang boleh manggil API.
# Format: schema + host (+ optional port), tanpa trailing slash.
#
# Per-deployment value (SaaS / on-prem masing-masing punya domain sendiri):
#   - SaaS Privasimu:  https://nexus.privasimu.com,https://privasimu.sainskerta.net
#   - On-prem klien A: https://privacy.client-a.example.com
#
# Migration first-boot bakal seed dari env ini. Setelah itu, UI
# /platform-admin/system-settings → Security → CORS jadi source of truth.
CORS_ALLOWED_ORIGINS=

# Set true untuk strip localhost dev origins dari seed (production-strict).
# Default: false — localhost tetap di-allow supaya dev convenience.
CORS_ALLOWED_ORIGINS_NO_LOCALHOST=false

# ═════════════════════════════════════════════════════════════════════
# Spatie Browsershot — render template PDF dengan CSS modern
# ═════════════════════════════════════════════════════════════════════
# Dipakai oleh 2 template ("Risograph Duotone" & "Cyber Glass") yang
# memerlukan mix-blend-mode, backdrop-filter, gradient text-clip, dan
# filter blur. Template lain tetap dirender melalui dompdf.

# Path absolut ke binary Chrome/Chromium. Kosongkan agar service mencoba
# mendeteksi otomatis. Contoh:
#   Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
#   Linux  : /usr/bin/google-chrome
BROWSERSHOT_CHROME_PATH=

# Path absolut ke binary Node.js. Wajib diisi bila Node diinstal melalui
# nvm atau tidak berada di PATH user PHP-FPM.
BROWSERSHOT_NODE_PATH=

# Batas waktu (detik) saat menjalankan headless Chrome. Naikkan bila
# server lambat memuat fonts/asset eksternal.
BROWSERSHOT_TIMEOUT=60

# Nonaktifkan sandbox Chromium. Wajib `true` di Docker/CI yang tidak
# menyediakan namespace untuk sandbox.
BROWSERSHOT_NO_SANDBOX=false
