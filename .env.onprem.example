# =============================================================================
# PRIVASIMU NEXUS — On-Prem Deployment Environment
# =============================================================================
# Copy to .env.onprem and adjust values before running install-onprem.sh.
# NEVER commit the populated .env.onprem to source control.

# ─── App ─────────────────────────────────────────────────────────────────
APP_URL=http://privasimu.bank-internal.local
# Generate via: docker run --rm php:8.3-cli php -r "echo 'base64:' . base64_encode(random_bytes(32));"
APP_KEY=

# ─── Landlord DB (platform metadata) ─────────────────────────────────────
LANDLORD_DB_NAME=privasimu_landlord
LANDLORD_DB_USER=privasimu_landlord
LANDLORD_DB_PASSWORD=        # REQUIRED — set a strong random value
LANDLORD_DB_PORT=5432

# ─── Tenant Cluster DB (per-tenant databases created by provisioner) ────
TENANT_DB_PROVISIONER_USER=privasimu_provisioner
TENANT_DB_PROVISIONER_PASSWORD=    # REQUIRED — pool will use this for CREATE DATABASE/USER
TENANT_DB_PORT=5433                # different host port from landlord

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=privasimu_redis_change_me
REDIS_PORT=6379

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────
MINIO_ROOT_USER=privasimu_minio_admin
MINIO_ROOT_PASSWORD=        # REQUIRED — min 8 chars
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Service ports ───────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
HTTP_PORT=80

# ─── Public API URL ──────────────────────────────────────────────────────
# Frontend uses this. /api means same-origin (nginx routes it).
PUBLIC_API_URL=/api

# ─── Logs ────────────────────────────────────────────────────────────────
# Host path where backend logs are mounted. Useful for SIEM ingestion.
BACKEND_LOGS_HOST_PATH=/opt/privasimu/logs

# ─── License Activation ──────────────────────────────────────────────────
# 'online' = phone home to license server on boot
# 'offline' = read static LICENSE_TOKEN_FILE for air-gapped installs
LICENSE_MODE=online
LICENSE_KEY=
LICENSE_SERVER_URL=https://license.privasimu.com
# LICENSE_TOKEN_FILE=/etc/privasimu/license.token   # only if LICENSE_MODE=offline
